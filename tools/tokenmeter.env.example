# Copy to tokenmeter.env and fill in your broker. tokenmeter.env is gitignored.
export MQTT_HOST="your-broker-host"
export MQTT_PORT="1883"
export MQTT_TOPIC="tabbie/cmd"
export MQTT_USER="tabbie"
export MQTT_PASS="your-broker-password"

export INTERVAL="5"
export METRIC="day"           # "day" = today's tokens; "peak" = session context peak
export METER_LIMIT="200000"
export METER_LABEL="DAY"
